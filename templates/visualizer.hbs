<div class="hotkey-visualizer-content">
  <header class="hotkey-visualizer-header">
    {{#unless keyboard}}
      <div class="hotkey-visualizer-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" class="hkv-search-input"
               placeholder="{{localize 'HOTKEYVIS.SearchPlaceholder'}}" autocomplete="off">
      </div>
      <div class="hotkey-visualizer-stats">
        {{localize 'HOTKEYVIS.ShownCount' shown=shown total=total}}
      </div>
    {{else}}
      <div class="hotkey-visualizer-kb-legend">
        <span class="hotkey-visualizer-kb-legend-swatch"></span>
        {{localize 'HOTKEYVIS.KeyboardLegend'}}
      </div>
    {{/unless}}
    <button type="button" class="hotkey-visualizer-view-toggle" data-action="toggleView"
            data-tooltip="{{localize toggleLabel}}">
      <i class="{{toggleIcon}}"></i> {{localize toggleLabel}}
    </button>
  </header>

  {{#if keyboard}}
    <div class="hkv-keyboard-view">
      <div class="hkv-keyboard">
        {{#each keyboardData.rows as |row|}}
          <div class="hkv-kb-row">
            {{#each row as |key|}}
              {{#if key.gap}}
                <span class="hkv-kb-gap" style="flex-grow: {{key.width}};"></span>
              {{else}}
                <span class="hkv-kb-key {{#if key.highlighted}}bound{{/if}}" style="flex-grow: {{key.width}};"
                      {{#if key.highlighted}}data-tooltip="{{key.tooltip}}"{{/if}}>{{key.label}}</span>
              {{/if}}
            {{/each}}
          </div>
        {{/each}}
      </div>

      <div class="hkv-keyboard-side">
        <div class="hkv-keyboard hkv-nav">
          {{#each keyboardData.nav as |row|}}
            <div class="hkv-kb-row">
              {{#each row as |key|}}
                {{#if key.gap}}
                  <span class="hkv-kb-gap"></span>
                {{else}}
                  <span class="hkv-kb-key {{#if key.highlighted}}bound{{/if}}"
                        {{#if key.highlighted}}data-tooltip="{{key.tooltip}}"{{/if}}>{{key.label}}</span>
                {{/if}}
              {{/each}}
            </div>
          {{/each}}
        </div>

        <div class="hkv-mouse" aria-label="Mouse">
          <div class="hkv-mouse-body">
            <span class="hkv-mouse-btn mouse-left"></span>
            <span class="hkv-mouse-btn mouse-right"></span>
            <span class="hkv-mouse-btn mouse-middle"></span>
          </div>
          <ul class="hkv-mouse-list">
            {{#each keyboardData.mouse as |btn|}}
              <li class="hkv-mouse-row {{#if btn.highlighted}}bound{{/if}}"
                  {{#if btn.highlighted}}data-tooltip="{{btn.tooltip}}"{{/if}}>{{btn.label}}</li>
            {{/each}}
          </ul>
        </div>
      </div>
    </div>
  {{else if empty}}
    <p class="hotkey-visualizer-empty notification">{{localize 'HOTKEYVIS.NoneVisible'}}</p>
  {{else}}
    <div class="hotkey-visualizer-list">
      {{#each groups as |group|}}
        <section class="hotkey-visualizer-group" data-namespace="{{group.namespace}}">
          <h2 class="hotkey-visualizer-group-title">{{group.label}}</h2>
          <div class="hotkey-visualizer-rows">
            {{#each group.actions as |action|}}
              <div class="hotkey-visualizer-row" data-search="{{action.name}} {{action.hint}}">
                <div class="hotkey-visualizer-row-main">
                  <div class="hotkey-visualizer-row-title">
                    <span class="hotkey-visualizer-name">{{action.name}}</span>
                    {{#each action.badges as |badge|}}
                      <span class="hotkey-visualizer-badge {{badge.cls}}">{{badge.label}}</span>
                    {{/each}}
                  </div>
                  {{#if action.hint}}
                    <p class="hotkey-visualizer-hint">{{action.hint}}</p>
                  {{/if}}
                  {{#if action.hasReserved}}
                    <p class="hotkey-visualizer-reserved">
                      {{localize 'HOTKEYVIS.ReservedModifiers'}}
                      {{#each action.reserved as |mod|}}
                        <kbd class="hotkey-chip {{mod.cls}}">{{mod.label}}</kbd>
                      {{/each}}
                    </p>
                  {{/if}}
                </div>
                <div class="hotkey-visualizer-row-keys">
                  {{#if action.hasBindings}}
                    {{#each action.bindings as |binding|}}
                      <span class="hotkey-binding">
                        {{#each binding.modifiers as |mod|}}
                          <kbd class="hotkey-chip {{mod.cls}}">{{mod.label}}</kbd>
                          <span class="hotkey-plus">+</span>
                        {{/each}}
                        <kbd class="hotkey-chip hotkey-key">{{binding.keyLabel}}</kbd>
                      </span>
                    {{/each}}
                  {{else}}
                    <span class="hotkey-unbound">{{localize 'HOTKEYVIS.Unbound'}}</span>
                  {{/if}}
                </div>
              </div>
            {{/each}}
          </div>
        </section>
      {{/each}}
    </div>
  {{/if}}
</div>
